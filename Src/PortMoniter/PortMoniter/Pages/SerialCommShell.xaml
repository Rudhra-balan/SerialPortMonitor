<Page x:Class="PortMoniter.Pages.Shell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:partialViews="clr-namespace:PortMoniter.Pages.PartialViews"
        Background="{DynamicResource Backdrop}"
        Title="{Binding WindowTitle}">
   
  <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
    

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Column="0"  BorderBrush="{DynamicResource Flat3DBorderBrush}" Grid.Row="0" Background="{DynamicResource Card}" CornerRadius="8" BorderThickness="1" Padding="4"  Margin="8,0,5,10">
                <Border.Effect>
                    <DropShadowEffect Direction="-75" ShadowDepth="2" Opacity="0.5" BlurRadius="5" />
                </Border.Effect>
                <Grid>
                       
                    <Grid.RowDefinitions>
                           <RowDefinition Height="Auto"/>
                       </Grid.RowDefinitions>
                       <partialViews:WriteDataView Grid.Row="0" Margin="5"/>
                   </Grid>
                </Border>

            <Border Grid.Row="1"  BorderBrush="{DynamicResource Flat3DBorderBrush}" Grid.Column="0" Background="{DynamicResource Card}" CornerRadius="8" BorderThickness="1" Padding="4"  Margin="8,0,5,10">
                <Border.Effect>
                    <DropShadowEffect Direction="-75" ShadowDepth="2" Opacity="0.5" BlurRadius="5" />
                </Border.Effect>
                <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <partialViews:ReadDataView Grid.Row="0" Margin="5"/>

                    </Grid>
                </Border>

            <Border Grid.Row="2"   CornerRadius="8 0 0 8" Background="{DynamicResource Backdrop}">
               
                <Grid x:Name="gridMenu" Height="80">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Menu -->
                    <ToggleButton x:Name="btnMenu"  HorizontalAlignment="Right" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Style="{DynamicResource ExpanderDownHeaderStyle}"  Margin="8,0,5,5">
                        <ToggleButton.Triggers>
                            <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                                <BeginStoryboard>
                                    <Storyboard x:Name="HideStackPanel">
                                        <DoubleAnimation Storyboard.TargetName="gridMenu" Storyboard.TargetProperty="Height" BeginTime="0:0:0" From="180" To="80" Duration="0:0:0.3">
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="ToggleButton.Checked">
                                <BeginStoryboard>
                                    <Storyboard x:Name="ShowStackPanel">
                                        <DoubleAnimation Storyboard.TargetName="gridMenu" Storyboard.TargetProperty="Height" BeginTime="0:0:0" From="80" To="180" Duration="0:0:0.3">
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ToggleButton.Triggers>
                    </ToggleButton>

                    <Border  BorderBrush="{DynamicResource Flat3DBorderBrush}" Grid.Row="1" Background="{DynamicResource Card}" CornerRadius="8" BorderThickness="1" Padding="4"  Margin="8,0,5,5">

                        <Border.Effect>
                            <DropShadowEffect Direction="-75" ShadowDepth="2" Opacity="0.5" BlurRadius="5" />
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <partialViews:FileExportSettingsView Grid.Row="0" Margin="5"/>

                        </Grid>
                    </Border>

                </Grid>
            </Border>
        </Grid>

      <Grid Grid.Column="1">
          <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

            <Border BorderBrush="{DynamicResource Flat3DBorderBrush}"  Grid.Column="0" Background="{DynamicResource Card}" CornerRadius="8" BorderThickness="1" Padding="4"  Margin="8,0,10,10">

              <Border.Effect>
                  <DropShadowEffect Direction="-75" ShadowDepth="2" Opacity="0.5" BlurRadius="5" />
              </Border.Effect>
                <Grid>
                  <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>

                  <partialViews:SerialPortSettingsView Grid.Row="0" Margin="5"/>


              </Grid>
          </Border>

            <Border  BorderBrush="{DynamicResource Flat3DBorderBrush}" Grid.Row="1" Grid.Column="0" Background="{DynamicResource Card}" CornerRadius="8" BorderThickness="1" Padding="4" Margin="8,0,10,10">
              
              <Border.Effect>
                  <DropShadowEffect Direction="-75" ShadowDepth="2" Opacity="0.5" BlurRadius="5" />
              </Border.Effect>
                <Grid>
                <GroupBox Header="INFO" Style="{StaticResource GroupBoxStyleOverride}">
                    <TextBlock Margin="5" TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryColor}">
                        SerialComm Monitor By default Hex string is enabled. Serial Device expected  Hex format i.e:- "a3 07 07 00 b1 00 a4". if disable can able to pass the normal string
                </TextBlock>
                </GroupBox>
            </Grid>
          </Border>


        </Grid>
    </Grid>
</Page>
