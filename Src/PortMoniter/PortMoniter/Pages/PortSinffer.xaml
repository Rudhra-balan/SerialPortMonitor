<Page x:Class="PortMoniter.Pages.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PortSniffer"
        xmlns:partialViews="clr-namespace:PortMoniter.Pages.PartialViews"
        xmlns:views="clr-namespace:PortMoniter.PartialViews.Dialogs.Views"
        xmlns:viewModels="clr-namespace:PortMoniter.ViewModels"
        d:DataContext="{d:DesignInstance Type=viewModels:MainViewModel}"
        Background="{DynamicResource Backdrop}" ShowsNavigationUI="True"
        Style="{DynamicResource MetroWindowStyle}"
        mc:Ignorable="d"
        x:Name="home"
        Title="MainWindow">
 
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition Height="400*"/>
            
        </Grid.RowDefinitions>

        <!--TitleBar-->
       
        <!--Products Section-->
        <Grid  Background="{DynamicResource Backdrop}" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!--Title-->


          
                <Grid  Grid.Column="0" Grid.Row="0" >

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="20 -25 0 0">
                        <TextBlock Text="{Binding WindowTitle}" FontSize="16" Foreground="{DynamicResource TextPrimaryColor}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

            <Border Grid.Column="0" BorderBrush="{DynamicResource Flat3DBorderBrush}" Grid.Row="1" Background="{DynamicResource Card}" CornerRadius="8" BorderThickness="1" Padding="5" Margin="8,0,5,5" >
                <Border.Effect>
                    <DropShadowEffect Direction="-75" ShadowDepth="2" Opacity="0.5" BlurRadius="5" />
                </Border.Effect>
                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <partialViews:ReadSnifferDataView  />
                </Grid>
            </Border>

            <Border Grid.Row="2"   CornerRadius="8 0 0 8" Background="{DynamicResource Backdrop}">

                <Grid x:Name="gridMenu" Height="80">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Menu -->
                    <ToggleButton x:Name="btnMenu"  HorizontalAlignment="Right" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Style="{DynamicResource ExpanderDownHeaderStyle}"  Margin="8,0,5,5">
                        <ToggleButton.Triggers>
                            <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                                <BeginStoryboard>
                                    <Storyboard x:Name="HideStackPanel">
                                        <DoubleAnimation Storyboard.TargetName="gridMenu" Storyboard.TargetProperty="Height" BeginTime="0:0:0" From="180" To="80" Duration="0:0:0.3">
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="ToggleButton.Checked">
                                <BeginStoryboard>
                                    <Storyboard x:Name="ShowStackPanel">
                                        <DoubleAnimation Storyboard.TargetName="gridMenu" Storyboard.TargetProperty="Height" BeginTime="0:0:0" From="80" To="180" Duration="0:0:0.3">
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ToggleButton.Triggers>
                    </ToggleButton>

                    <Border  BorderBrush="{DynamicResource Flat3DBorderBrush}" Grid.Row="1" Background="{DynamicResource Card}" CornerRadius="8" BorderThickness="1" Padding="4"  Margin="8,0,5,5">

                        <Border.Effect>
                            <DropShadowEffect Direction="-75" ShadowDepth="2" Opacity="0.5" BlurRadius="5" />
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <partialViews:SettingSnifferDataView Margin="5"/>
                            

                        </Grid>
                    </Border>

                </Grid>
            </Border>
        </Grid>

        <!--Card Section-->
        <Grid Grid.Column="1" Background="Transparent" Grid.Row="1" Margin="5,-10,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
          

            <Border Grid.Column="0" Grid.Row="1" BorderBrush="{DynamicResource Flat3DBorderBrush}"   Background="{DynamicResource Card}" CornerRadius="8" BorderThickness="1" Padding="8" Margin="4,0,5,0">
                <Border.Effect>
                    <DropShadowEffect Direction="-75" ShadowDepth="2" Opacity="0.5" BlurRadius="5"  Color="#424754" />
                </Border.Effect>
                <views:SinfferExport  />
            </Border>

            <Border Grid.Column="0" Grid.Row="0" BorderBrush="{DynamicResource Flat3DBorderBrush}"  Background="{DynamicResource Card}" CornerRadius="8" BorderThickness="1" Padding="8" Margin="4,10,4,8">
                <Border.Effect>
                    <DropShadowEffect Direction="-75" ShadowDepth="2" Opacity="0.5" BlurRadius="5"  Color="#424754" />
                </Border.Effect>
                <partialViews:PortSettingSnifferDataView />
            </Border>
            <Border Grid.Row="2" VerticalAlignment="Bottom" Grid.Column="0" Height="60" BorderBrush="{DynamicResource Flat3DBorderBrush}" Background="{DynamicResource Card}" CornerRadius="8"  Margin="4,4,4,4">

                <Border.Effect>
                    <DropShadowEffect Direction="-75" ShadowDepth="2" Opacity="0.5" BlurRadius="5" Color="#424754" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button  Visibility="{Binding StartButtonVisible}" Content="Start Monitoring" Style="{DynamicResource buttonCheckout}"  Command="{Binding StartMonitoring}"  />
                    <Button Visibility="{Binding StopButtonVisible}" Content="Stop Monitoring" Style="{StaticResource buttonStopout}"  Command="{Binding Close}"   />


                </Grid>
            </Border>

           
        </Grid>

       
    </Grid>
</Page>
