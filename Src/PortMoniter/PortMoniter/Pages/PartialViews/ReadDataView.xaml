<UserControl x:Class="PortMoniter.Pages.PartialViews.ReadDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:PortMoniter.Controls"

             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
        <GroupBox Header="READ DATA" Style="{DynamicResource GroupBoxStyleOverride}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBox Grid.Row="0" Foreground="{DynamicResource TextPrimaryColor}" x:Name="OutputBox" controls:TextBoxAutomaticScrollingExtension.ScrollOnTextChanged="{Binding ScrollOnTextChanged}" Text="{Binding OutputText}" Margin="5" IsReadOnly="True"  VerticalScrollBarVisibility="Visible" TextWrapping="Wrap" FontFamily="Consolas"/>
                <!--<TextBox Grid.Row="0" Foreground="{DynamicResource TextPrimaryColor}" x:Name="OutputBox" controls:TextBoxAutomaticScrollingExtension.ScrollOnTextChanged="{Binding ScrollOnTextChanged}" Text="{Binding OutputText}" Margin="5" IsReadOnly="True"  VerticalScrollBarVisibility="Visible" TextWrapping="Wrap" FontFamily="Consolas"/>-->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Style="{DynamicResource SerialPortCheckbox}" Grid.Column="0" x:Name="Autoscroll" VerticalAlignment="Center" VerticalContentAlignment="Center" IsChecked="{Binding IsAutoscrollChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Content="{Binding ScrollConfirm}" IsEnabled="False"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Width="110" Height="30" Style="{DynamicResource btnBlue}" Content="Clear" Margin="0 0 5 0" Command="{Binding Clear}"/>
                        <ComboBox Width="110" Height="30" HorizontalAlignment="Right" Style="{DynamicResource ComboBoxFlatStyle}" VerticalAlignment="Center" ItemsSource="{Binding LineEndings}" DisplayMemberPath="LineEndingName" SelectedValue="{Binding SelectedLineEnding, Mode=TwoWay}" SelectedValuePath="LineEndingChars" Margin="0 0 5 0"  />
                    </StackPanel>
                </Grid>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
