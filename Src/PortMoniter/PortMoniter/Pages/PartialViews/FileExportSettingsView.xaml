<UserControl x:Class="PortMoniter.Pages.PartialViews.FileExportSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converter="clr-namespace:PortMoniter.Controls.Converter"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <UserControl.Resources>
        <converter:BrushColorConverter x:Key="BoolToColorConverter"></converter:BrushColorConverter>
    </UserControl.Resources>
    <Grid>
        <GroupBox Header="Export Data" Style="{DynamicResource GroupBoxStyleOverride}">
            <Grid Margin="15,15,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                 <StackPanel Orientation="Horizontal">
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="15 0 0 0" Orientation="Vertical">
                        <StackPanel  Orientation="Horizontal" Margin="0 0 0 0">
                            <Label Content="File location"  Foreground= "{DynamicResource TextSecundaryColor}" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="5 0 0 0">
                            <TextBox Foreground="{DynamicResource TextPrimaryColor}" Width="200" Text="{Binding FileLocation}" IsReadOnly="True"/>
                            <Button Style="{DynamicResource btnBlue}" Width="25" Margin="5 0 0 0" ToolTip="Change file location" Command="{Binding ChangeFileLocation}">
                                <Path Data="M16,12A2,2 0 0,1 18,10A2,2 0 0,1 20,12A2,2 0 0,1 18,14A2,2 0 0,1 16,12M10,12A2,2 0 0,1 12,10A2,2 0 0,1 14,12A2,2 0 0,1 12,14A2,2 0 0,1 10,12M4,12A2,2 0 0,1 6,10A2,2 0 0,1 8,12A2,2 0 0,1 6,14A2,2 0 0,1 4,12Z" Fill="{StaticResource ForegroundBrush}" Stretch="Uniform" />
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="15 0 0 0" Orientation="Vertical">
                        <StackPanel  Orientation="Horizontal" Margin="0 0 0 0">
                            <Label Content="Filename"  Foreground= "{DynamicResource TextSecundaryColor}" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="5 0 0 0">
                            <TextBox Foreground="{DynamicResource TextPrimaryColor}" Width="100" Text="{Binding FileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="50"/>
                            <ComboBox Style="{DynamicResource ComboBoxFlatStyle}" ItemsSource="{Binding FileExtensions}" SelectedItem="{Binding SelectedFileExtension}" MinWidth="100" Margin="5 0 0 0"/>

                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="2" HorizontalAlignment="Center" Orientation="Horizontal" Margin="0 0 0 5">
                        <Button  Height="30" Width="110" Style="{DynamicResource btnBlue}" Content="Export Now" Margin="20 25 0 0" Command="{Binding ExportFile}"/>
                    </StackPanel>
                  </StackPanel>
            </Grid>

        </GroupBox>
    </Grid>
</UserControl>
