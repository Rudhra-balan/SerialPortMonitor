<UserControl x:Class="PortMoniter.Pages.PartialViews.PortSettingSnifferDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="200">
    <Grid>
        <GroupBox Header="PORT CONFIGURATION" Style="{DynamicResource GroupBoxStyleOverride}">
            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical">
                    <StackPanel  Orientation="Horizontal" Margin="0 0 0 0">
                        <Label Content="Port"  Foreground= "{DynamicResource TextSecundaryColor}" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5 0 0 0">
                        <ComboBox IsEnabled="{Binding EnableDisableSettings}"  ItemsSource="{Binding AvailablePorts}" Style="{DynamicResource ComboBoxFlatStyle}"  SelectedValue="{Binding RealPort, Mode=TwoWay}" Width="200" Height="30"/>
                        <Button Margin="5,0,0,0" Foreground="{DynamicResource PrimaryBlueColor}" Style="{DynamicResource IconButtonsStyle}" IsEnabled="{Binding EnableDisableSettings}"   Command="{Binding RefreshPorts}"  Content="{DynamicResource Refresh}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Vertical">
                    <StackPanel  Orientation="Horizontal" Margin="0 0 0 0">
                        <Label Content="Baud Rate"  Foreground= "{DynamicResource TextSecundaryColor}" FontSize="12"/>
                    </StackPanel>
                    <StackPanel  Orientation="Horizontal" Margin="5 0 0 0">
                        <ComboBox  IsEnabled="{Binding EnableDisableSettings}"  ItemsSource="{Binding BaudRate}" Style="{DynamicResource ComboBoxFlatStyle}"  SelectedValue="{Binding SelectedBaudRate, Mode=TwoWay}" 
                        Width="200" Height="30" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Vertical">
                    <StackPanel  Orientation="Horizontal" Margin="0 0 0 0">
                        <Label Content="Parity"  Foreground= "{DynamicResource TextSecundaryColor}" FontSize="12"/>
                    </StackPanel>
                    <StackPanel  Orientation="Horizontal" Margin="5 0 0,0 ">
                        <ComboBox  IsEnabled="{Binding EnableDisableSettings}"  ItemsSource="{Binding Parity}" Style="{DynamicResource ComboBoxFlatStyle}"  SelectedValue="{Binding SelectedParity, Mode=TwoWay}" 
                        Width="200" Height="30" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Vertical">
                    <StackPanel  Orientation="Horizontal" Margin="0 0 0 0">
                        <Label Content="Data Bits"  Foreground= "{DynamicResource TextSecundaryColor}" FontSize="12"/>
                    </StackPanel>
                    <StackPanel  Orientation="Horizontal" Margin="5 0 0 0">
                        <ComboBox IsEnabled="{Binding EnableDisableSettings}"   ItemsSource="{Binding DataBits}" Style="{DynamicResource ComboBoxFlatStyle}"  SelectedValue="{Binding SelectedDataBits, Mode=TwoWay}" 
                       Width="200" Height="30" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Vertical">
                    <StackPanel  Orientation="Horizontal" Margin="0 0 0 0">
                        <Label Content="Stop Bits"  Foreground= "{DynamicResource TextSecundaryColor}" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5 0 0 0">
                        <ComboBox IsEnabled="{Binding EnableDisableSettings}"   ItemsSource="{Binding StopBits}" Style="{DynamicResource ComboBoxFlatStyle}"  SelectedValue="{Binding SelectedStopBits, Mode=TwoWay}" 
                       Width="200" Height="30" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Row="5" Grid.Column="0" Orientation="Vertical">
                    <StackPanel  Orientation="Horizontal" Margin="0 0 0 0">
                        <Label Content="Port Forwarding" Foreground= "{DynamicResource TextSecundaryColor}" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5 0 0 0">
                        <ComboBox DisplayMemberPath="PortNameA" IsEnabled="{Binding EnableDisableSettings}"   ItemsSource="{Binding VirtualPorts}" Style="{DynamicResource ComboBoxFlatStyle}" SelectedValue="{Binding VirtualPort, Mode=TwoWay}" 
                       Width="200" Height="30"  />
                        <Button  Margin="5,0,0,0"   IsEnabled="{Binding EnableDisableSettings}" Style="{DynamicResource IconButtonsStyle}"  Command="{Binding RefreshPorts}" Content="{DynamicResource Refresh}" Foreground="{DynamicResource PrimaryBlueColor}" />
                    </StackPanel>
                </StackPanel>

            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
