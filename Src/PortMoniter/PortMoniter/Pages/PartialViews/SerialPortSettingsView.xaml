<UserControl x:Class="PortMoniter.Pages.PartialViews.SerialPortSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <GroupBox Grid.Row="0" Header="SERIAL PORT SETTINGS" Style="{DynamicResource GroupBoxStyleOverride}">
            <Grid>
               
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical">
                    <StackPanel  Orientation="Horizontal" Margin="0 0 0 0">
                        <Label Content="Port"  Foreground= "{DynamicResource TextSecundaryColor}" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5 0 0 0">
                        <ComboBox ItemsSource="{Binding CommPorts}" DisplayMemberPath="DeviceInfo" SelectedItem="{Binding SelectedCommPort, Mode=TwoWay}" Width="200" Height="30"
                                  IsEnabled="{Binding EnableDisableSettings}" Style="{DynamicResource ComboBoxFlatStyle}"/>
                        <Button Style="{DynamicResource IconButtonsStyle}" Foreground="{DynamicResource TextPrimaryColor}" Width="30" Margin="5 0 0 0" ToolTip="Refresh COM* ports" Content="{DynamicResource Refresh}" Command="{Binding RefreshPorts}">
                            </Button>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Vertical">
                    <StackPanel  Orientation="Horizontal" Margin="0 0 0 0">
                        <Label Content="Baud Rate"  Foreground= "{DynamicResource TextSecundaryColor}" FontSize="12"/>
                    </StackPanel>
                    <StackPanel  Orientation="Horizontal" Margin="5 0 0 0">
                        <ComboBox ItemsSource="{Binding BaudRates}" DisplayMemberPath="BaudRateName" SelectedValue="{Binding SelectedBaudRate, Mode=TwoWay}" SelectedValuePath="BaudRateValue"
                                  IsEnabled="{Binding EnableDisableSettings}" Style="{DynamicResource ComboBoxFlatStyle}" Width="200" Height="30"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Vertical">
                    <StackPanel  Orientation="Horizontal" Margin="0 0 0 0">
                        <Label Content="Parity"  Foreground= "{DynamicResource TextSecundaryColor}" FontSize="12"/>
                    </StackPanel>
                    <StackPanel  Orientation="Horizontal" Margin="5 0 0,0 ">
                        <ComboBox ItemsSource="{Binding Parities}" DisplayMemberPath="ParityName" SelectedValue="{Binding SelectedParity, Mode=TwoWay}" SelectedValuePath="ParityValue"
                                  IsEnabled="{Binding EnableDisableSettings}" Style="{DynamicResource ComboBoxFlatStyle}" Width="200" Height="30"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Vertical">
                    <StackPanel  Orientation="Horizontal" Margin="0 0 0 0">
                        <Label Content="Data Bits"  Foreground= "{DynamicResource TextSecundaryColor}" FontSize="12"/>
                    </StackPanel>
                    <StackPanel  Orientation="Horizontal" Margin="5 0 0 0">
                        <ComboBox ItemsSource="{Binding DataBits}" SelectedItem="{Binding SelectedDataBits, Mode=TwoWay}"
                                  IsEnabled="{Binding EnableDisableSettings}" Style="{DynamicResource ComboBoxFlatStyle}" Width="200" Height="30"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Vertical">
                    <StackPanel  Orientation="Horizontal" Margin="0 0 0 0">
                        <Label Content="Stop Bits"  Foreground= "{DynamicResource TextSecundaryColor}" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5 0 0 0">
                        <ComboBox ItemsSource="{Binding StopBitsList}" DisplayMemberPath="StopBitsName" SelectedValue="{Binding SelectedStopBits, Mode=TwoWay}" SelectedValuePath="StopBitsValue"
                                  IsEnabled="{Binding EnableDisableSettings}" Style="{DynamicResource ComboBoxFlatStyle}" Width="200" Height="30"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Row="5" Grid.Column="0" Orientation="Vertical">
                    <StackPanel  Orientation="Horizontal" Margin="0 0 0 0">
                        <Label Content="Flow Control" Foreground= "{DynamicResource TextSecundaryColor}" FontSize="12"/>
                    </StackPanel>
                    <StackPanel  Orientation="Horizontal" Margin="5 0 0 0">
                        <ComboBox ItemsSource="{Binding FlowControlList}" DisplayMemberPath="FlowControlName" SelectedValue="{Binding SelectedFlowControl, Mode=TwoWay}" SelectedValuePath="FlowControlValue"
                                  IsEnabled="{Binding EnableDisableSettings}" Style="{DynamicResource ComboBoxFlatStyle}" Width="200" Height="30"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="0" Grid.Row="6" Orientation="Horizontal" Margin="3,13,3,3">
                    <CheckBox Style="{DynamicResource SerialPortCheckbox}"  Margin="5,0,0,0"  VerticalAlignment="Center" VerticalContentAlignment="Center" IsChecked="{Binding IsRTS, Mode=TwoWay}" Content="Request To Send" 
                                      IsEnabled="{Binding EnableDisableSettings}"/>
                    <CheckBox Style="{DynamicResource SerialPortCheckbox}"   VerticalAlignment="Center" VerticalContentAlignment="Center" IsChecked="{Binding IsDTR, Mode=TwoWay}" Content="Data Terminal Ready" Margin="5,0,0,0"
                              IsEnabled="{Binding EnableDisableSettings}"/>
                </StackPanel>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="1" Header="SWITCH" Margin="0 5 0 0" Style="{DynamicResource GroupBoxStyleOverride}">
            <Grid>
                <Button Grid.Column="0" Grid.Row="0"  Style="{DynamicResource btnBlue}" Width="200" Height="50" Visibility="{Binding StartButtonVisible}" Content="START COMMUNICATION" Command="{Binding Open}" Padding="10 3" Margin="5"/>
                <Button Grid.Column="0" Grid.Row="0"  Style="{DynamicResource btnBlue}" Width="200" Height="50" Visibility="{Binding StopButtonVisible}" Content="STOP COMMUNICATION" Command="{Binding Close}" Padding="10 3" Margin="5"
                               Foreground="Red"/>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
