<UserControl x:Class="PortMoniter.Pages.PartialViews.SettingSnifferDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
        <GroupBox Header="VIRTUAL PORT" Style="{DynamicResource GroupBoxStyleOverride}">
            <Grid>
                <Grid.RowDefinitions>
                    <!--<RowDefinition/>-->
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <!--<StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical">
                    <StackPanel  Orientation="Horizontal" Margin="0 0 0 0">
                        <Label Content="Virtual Port"  Foreground= "{DynamicResource TextSecundaryColor}" FontSize="12"/>
                    </StackPanel>
                    <StackPanel  Orientation="Horizontal" Margin="5 0 0 0">
                       
                        <ComboBox Style="{DynamicResource ComboBoxFlatStyle}" IsEnabled="{Binding EnableDisableSettings}"   Margin="0 0 0 0" ItemsSource="{Binding VirtualPorts}" DisplayMemberPath="PortNameA"  SelectedValue="{Binding VirtualPort, Mode=TwoWay}" 
                                  Width="200" Height="30" />
                    </StackPanel>
                </StackPanel>-->
               
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left"  Margin="0,5">
                    <Button  Margin="5" Height="30"  Width="110"  Content=" Create " Style="{DynamicResource btnBlue}" Command="{Binding CreateVirtualPort}" />
                    <Button  Margin="5" Height="30" Width="110"   Content=" Delete " Style="{DynamicResource btnBlue}" Command="{Binding DeleteVirtualPort}" />
                </StackPanel>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
